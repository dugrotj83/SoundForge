// ── CORS preflight ──
if (request.method === 'OPTIONS') {
  return new Response(null, {
    status: 204,
    headers: corsHeaders(),
  });
}

// ── Only allow POST ──
if (request.method !== 'POST') {
  return json({ error: 'Only POST allowed' }, 405);
}

// ── Parse body ──
let body;
try {
  body = await request.json();
} catch {
  return json({ error: 'Invalid JSON body' }, 400);
