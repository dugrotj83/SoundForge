  body: JSON.stringify({ inputs, parameters }),
});

// ── Pass audio blob straight back ──
const responseHeaders = {
  ...corsHeaders(),
  'Content-Type': hfResponse.headers.get('Content-Type') || 'audio/wav',
  'Cache-Control': 'no-store',
};

// Forward non-200 as JSON error
