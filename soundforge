const DURATION_MAP = { '0:30': 8, '1:00': 15, '2:00': 22, '3:00': 30, '4:00': 30 };

// ── MUSIC GENERATION ──
// WORKER_URL is set by the user after deploying their Cloudflare Worker.
// If empty, we fall back to direct HF calls (works on desktop, blocked on iOS Safari).
let WORKER_URL = ''; // e.g. https://soundforge.yourname.workers.dev

async function generateMusicHF(musicPrompt, durationSecs) {
  const body = {
    inputs: musicPrompt,
    parameters: { max_new_tokens: Math.min(durationSecs * 50, 500) }
  };

  // ── Path A: Cloudflare Worker (works everywhere including iOS) ──
  if (WORKER_URL) {
    setStatus('Connecting to your proxy…', 57);
    let res;
    try {
      res = await fetch(WORKER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ hfKey: HF_KEY, ...body })
      });
    } catch(e) {
      throw new Error('Could not reach your Cloudflare Worker. Check the URL in Token setup.');
    }

    // Worker-side warm-up loop
    let warmRetries = 0;
    while (res.status === 503 && warmRetries < 3) {
      warmRetries++;
      setStatus(`Model warming up… (${warmRetries}/3)`, 60 + warmRetries * 8);
      await new Promise(r => setTimeout(r, 18000));
      if (cancelRequested) throw new Error('cancelled');
      res = await fetch(WORKER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ hfKey: HF_KEY, ...body })
      });
    }

    if (res.status === 401 || res.status === 403)
      throw new Error('Invalid HF token — paste a fresh one from huggingface.co/settings/tokens');
    if (res.status === 429)
      throw new Error('Rate limited — wait 60 seconds and try again');
    if (!res.ok) {
      let msg = `HTTP ${res.status}`;
      try { const j = await res.json(); msg = j.error || msg; } catch {}
      throw new Error('Worker error: ' + msg);
    }

    const blob = await res.blob();
    if (blob.size < 500) throw new Error('Empty audio — model may be loading. Try again in 30s.');
    return URL.createObjectURL(blob);
  }

  // ── Path B: Direct HF call (desktop browsers only) ──
  setStatus('Connecting to Hugging Face…', 57);
  const ENDPOINTS = [
    'https://router.huggingface.co/hf-inference/models/facebook/musicgen-small',
    'https://api-inference.huggingface.co/models/facebook/musicgen-small',
  ];

  let lastError = 'Connection blocked by browser. Set up a Cloudflare Worker for mobile support.';

  for (let ei = 0; ei < ENDPOINTS.length; ei++) {
    if (cancelRequested) throw new Error('cancelled');
    setStatus(`Trying endpoint ${ei + 1}/${ENDPOINTS.length}…`, 57 + ei * 8);
    let res;
    try {
      res = await fetch(ENDPOINTS[ei], {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${HF_KEY}`, 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
    } catch(e) {
      lastError = ei === ENDPOINTS.length - 1
        ? 'Blocked by browser CORS policy. You need to set up a Cloudflare Worker — tap Token to add the Worker URL.'
        : `Endpoint ${ei + 1} blocked, trying next…`;
      continue;
    }

    let warmRetries = 0;
    while (res.status === 503 && warmRetries < 2) {
      warmRetries++;
      setStatus(`Model warming up… (${warmRetries}/2)`, 65);
      await new Promise(r => setTimeout(r, 18000));
      if (cancelRequested) throw new Error('cancelled');
      try { res = await fetch(ENDPOINTS[ei], { method: 'POST', headers: { 'Authorization': `Bearer ${HF_KEY}`, 'Content-Type': 'application/json' }, body: JSON.stringify(body) }); }
      catch(e) { break; }
    }

    if (res.status === 401 || res.status === 403)
      throw new Error('Invalid HF token — paste a fresh one from huggingface.co/settings/tokens');
    if (res.status === 429) throw new Error('Rate limited — wait 60 seconds');
    if (res.status === 503) { lastError = 'Model loading — try again in 30s'; continue; }
    if (!res.ok) { try { const j = await res.json(); lastError = j.error || `HTTP ${res.status}`; } catch { lastError = `HTTP ${res.status}`; } continue; }

    const blob = await res.blob();
    if (blob.size < 500) { lastError = 'Empty audio — try again'; continue; }
    return URL.createObjectURL(blob);
  }

  throw new Error(lastError);
}


// ── MAIN GENERATION FLOW ──
async function startGeneration() {
  const prompt = document.getElementById('promptInput').value.trim();
  if (!prompt) { showToast('Add a description first', '⚠️'); return; }

  cancelRequested = false;
  document.getElementById('generateBtn').disabled = true;
  document.getElementById('genStatus').classList.add('visible');
  document.getElementById('resultSection').classList.remove('visible');

  const genre = document.getElementById('genreSelect').value;
  const mood = document.getElementById('moodSelect').value;
  const bpm = document.getElementById('bpmVal').textContent;
  const durationSecs = DURATION_MAP[selectedDuration] || 8;
  const isInstrumental = currentMode === 'instrumental';
  const customLyrics = currentMode === 'custom' ? document.getElementById('lyricsInput').value.trim() : '';

  // Generate metadata locally (instant, no API)
  const meta = generateMetadata(prompt, genre, mood, bpm);
  const songLyrics = customLyrics || meta.lyrics;

  let audioUrl = null;

  try {
    markStep('step1', 'active');
    setStatus('Crafting your prompt…', 15);
    await new Promise(r => setTimeout(r, 500));
    if (cancelRequested) throw new Error('cancelled');

    markStep('step1', 'done'); markStep('step2', 'active');
    setStatus('Composing structure…', 35);
    await new Promise(r => setTimeout(r, 600));
    if (cancelRequested) throw new Error('cancelled');

    markStep('step2', 'done'); markStep('step3', 'active');
    setStatus('Generating audio with MusicGen…', 55);

    const musicPrompt = `${genre}, ${mood}, ${bpm} BPM. ${prompt}${isInstrumental ? ', no vocals, instrumental' : ''}`;

    if (!demoMode && HF_KEY) {
      audioUrl = await generateMusicHF(musicPrompt, durationSecs);
    } else {
      // Simulate for demo mode
      for (let p = 55; p <= 88; p += 5) {
        if (cancelRequested) throw new Error('cancelled');
        await new Promise(r => setTimeout(r, 500));
        document.getElementById('statusBar').style.width = p + '%';
      }
    }

    if (cancelRequested) throw new Error('cancelled');

    markStep('step3', 'done'); markStep('step4', 'active');
    setStatus('Mastering…', 95);
    await new Promise(r => setTimeout(r, 500));
    markStep('step4', 'done');
    setStatus('Done!', 100);
    await new Promise(r => setTimeout(r, 300));

  } catch (err) {
    document.getElementById('genStatus').classList.remove('visible');
    document.getElementById('generateBtn').disabled = false;
    ['step1','step2','step3','step4'].forEach(id => markStep(id, null));
    document.getElementById('statusBar').style.width = '0%';
    if (err.message !== 'cancelled') {
      showErrorBanner(err.message);
    }
    return;
  }

  document.getElementById('genStatus').classList.remove('visible');
  document.getElementById('generateBtn').disabled = false;
  ['step1','step2','step3','step4'].forEach(id => markStep(id, null));
  document.getElementById('statusBar').style.width = '0%';

  const emoji = EMOJIS[Math.floor(Math.random() * EMOJIS.length)];
  const gradient = GRADIENTS[Math.floor(Math.random() * GRADIENTS.length)];

  const song = {
    title: meta.title, tagline: meta.tagline, tags: meta.tags,
    emoji, gradient, duration: selectedDuration,
    genre, mood, bpm, lyrics: songLyrics, prompt, audioUrl,
    isDemo: !audioUrl
  };

  songs.unshift(song);
  currentSongIdx = 0;
  renderResult(song);
  renderSongsList();
  updateNowPlayingAudio(song);
  showToast(`"${meta.title}" created!`, '🎵');
}

function cancelGeneration() {
  cancelRequested = true;
  document.getElementById('genStatus').classList.remove('visible');
  document.getElementById('generateBtn').disabled = false;
  ['step1','step2','step3','step4'].forEach(id => markStep(id, null));
  document.getElementById('statusBar').style.width = '0%';
  showToast('Cancelled', '✕');
}

