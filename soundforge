<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>SOUNDFORGE — AI Music Studio</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–bg: #080810;
–surface: #0e0e1a;
–surface2: #141425;
–border: rgba(255,255,255,0.07);
–border2: rgba(255,255,255,0.12);
–neon: #00ffe1;
–neon2: #ff2d78;
–neon3: #a259ff;
–gold: #ffd166;
–text: #eeeef8;
–muted: #5a5a80;
–dim: #2a2a40;
–radius: 14px;
–font-display: ‘Bebas Neue’, sans-serif;
–font-body: ‘DM Sans’, sans-serif;
–font-mono: ‘JetBrains Mono’, monospace;
}

html, body { height: 100%; }

/* ========== MOBILE (default) ========== */
body {
font-family: var(–font-body);
color: var(–text);
background: var(–bg);
overflow-x: hidden;
}

/* Grain */
body::before {
content: ‘’;
position: fixed; inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘1’/%3E%3C/svg%3E”);
opacity: 0.025; pointer-events: none; z-index: 9999;
}

/* Glowing orbs */
.orb { position: fixed; border-radius: 50%; pointer-events: none; filter: blur(80px); z-index: 0; }
.orb1 { width: 400px; height: 400px; background: rgba(0,255,225,0.06); top: -100px; right: -100px; }
.orb2 { width: 350px; height: 350px; background: rgba(162,89,255,0.06); bottom: 100px; left: -80px; }

/* ── MOBILE LAYOUT ── */
.app-mobile {
display: flex;
flex-direction: column;
min-height: 100vh;
padding-bottom: 130px; /* space for player + nav */
}

/* Mobile header */
.mobile-header {
display: flex;
align-items: center;
justify-content: space-between;
padding: 16px 20px 12px;
border-bottom: 1px solid var(–border);
background: var(–surface);
position: sticky; top: 0; z-index: 50;
}
.mobile-logo {
font-family: var(–font-display);
font-size: 26px; letter-spacing: 3px;
color: var(–neon);
text-shadow: 0 0 16px rgba(0,255,225,0.4);
}
.mobile-header-right { display: flex; gap: 10px; align-items: center; }
.hdr-btn {
background: var(–surface2); border: 1px solid var(–border2);
border-radius: 8px; color: var(–muted);
padding: 8px 12px; cursor: pointer;
font-family: var(–font-mono); font-size: 11px;
letter-spacing: 0.08em; text-transform: uppercase;
display: flex; align-items: center; gap: 6px;
-webkit-tap-highlight-color: transparent;
transition: all 0.2s;
}
.hdr-btn:active { border-color: var(–neon); color: var(–neon); }

/* Mobile tab bar */
.mobile-tabs {
display: flex;
background: var(–surface);
border-bottom: 1px solid var(–border);
padding: 0 20px;
gap: 0;
overflow-x: auto;
scrollbar-width: none;
}
.mobile-tabs::-webkit-scrollbar { display: none; }
.mtab {
padding: 14px 20px;
font-family: var(–font-mono); font-size: 11px;
letter-spacing: 0.1em; text-transform: uppercase;
color: var(–muted); background: none; border: none;
cursor: pointer; white-space: nowrap;
border-bottom: 2px solid transparent;
transition: all 0.2s;
-webkit-tap-highlight-color: transparent;
}
.mtab.active { color: var(–neon); border-bottom-color: var(–neon); }

/* Tab panels */
.tab-panel { display: none; padding: 20px; }
.tab-panel.active { display: flex; flex-direction: column; gap: 20px; }

/* ── STUDIO PANEL ── */
.studio-hero {
text-align: center;
padding: 10px 0 4px;
}
.studio-title {
font-family: var(–font-display);
font-size: 44px; letter-spacing: 4px; line-height: 0.9;
background: linear-gradient(135deg, var(–text) 0%, var(–neon) 60%, var(–neon3) 100%);
-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.studio-sub {
font-size: 13px; color: var(–muted); margin-top: 8px;
font-weight: 300;
}

/* Mode tabs */
.mode-row {
display: flex; gap: 2px;
background: var(–surface); border: 1px solid var(–border);
border-radius: 10px; padding: 3px;
}
.mode-tab {
flex: 1; padding: 10px 6px;
border-radius: 7px; border: none; background: none;
color: var(–muted); font-family: var(–font-body);
font-size: 12px; font-weight: 500;
cursor: pointer; transition: all 0.2s; text-align: center;
-webkit-tap-highlight-color: transparent;
}
.mode-tab.active { background: var(–surface2); color: var(–text); box-shadow: 0 1px 4px rgba(0,0,0,0.4); }

/* Prompt box */
.prompt-card {
background: var(–surface); border: 1px solid var(–border2);
border-radius: var(–radius); padding: 18px;
transition: border-color 0.3s;
}
.prompt-card:focus-within { border-color: rgba(0,255,225,0.35); }
.prompt-label {
font-family: var(–font-mono); font-size: 10px;
letter-spacing: 0.15em; text-transform: uppercase;
color: var(–muted); margin-bottom: 10px;
display: flex; align-items: center; gap: 8px;
}
.prompt-label::after { content: ‘’; flex: 1; height: 1px; background: var(–border); }
.prompt-input {
width: 100%; background: none; border: none; outline: none;
color: var(–text); font-family: var(–font-body);
font-size: 16px; font-weight: 400; line-height: 1.6;
resize: none; min-height: 80px;
}
.prompt-input::placeholder { color: var(–dim); }
.prompt-footer {
display: flex; justify-content: space-between; align-items: center;
margin-top: 12px; padding-top: 12px;
border-top: 1px solid var(–border);
}
.char-count { font-family: var(–font-mono); font-size: 11px; color: var(–muted); }

/* Tag pills */
.tag-pills { display: flex; gap: 6px; flex-wrap: wrap; }
.tag-pill {
font-family: var(–font-mono); font-size: 11px;
padding: 6px 12px; border-radius: 100px;
border: 1px solid var(–border2); color: var(–muted);
cursor: pointer; transition: all 0.2s; white-space: nowrap;
background: none; -webkit-tap-highlight-color: transparent;
}
.tag-pill.selected, .tag-pill:active {
border-color: var(–neon); color: var(–neon); background: rgba(0,255,225,0.08);
}

/* Lyrics panel */
.lyrics-card {
background: var(–surface); border: 1px solid var(–border2);
border-radius: var(–radius); padding: 18px;
}
.lyrics-textarea {
width: 100%; background: none; border: none; outline: none;
color: var(–text); font-family: var(–font-body);
font-size: 15px; line-height: 1.6; resize: none; min-height: 120px;
}

/* Controls grid */
.controls-grid {
display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
}
.control-group { display: flex; flex-direction: column; gap: 8px; }
.control-label {
font-family: var(–font-mono); font-size: 10px;
letter-spacing: 0.12em; text-transform: uppercase; color: var(–muted);
}
.control-select {
background: var(–surface); border: 1px solid var(–border2);
border-radius: 10px; color: var(–text);
font-family: var(–font-body); font-size: 15px;
padding: 13px 14px; outline: none; cursor: pointer;
appearance: none; width: 100%;
background-image: url(“data:image/svg+xml,%3Csvg width=‘12’ height=‘8’ viewBox=‘0 0 12 8’ fill=‘none’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cpath d=‘M1 1L6 7L11 1’ stroke=’%235a5a80’ stroke-width=‘1.5’ stroke-linecap=‘round’ stroke-linejoin=‘round’/%3E%3C/svg%3E”);
background-repeat: no-repeat; background-position: right 12px center;
-webkit-tap-highlight-color: transparent;
}
.control-select option { background: var(–surface2); }
.bpm-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
.control-slider {
-webkit-appearance: none; width: 100%; height: 6px;
background: var(–dim); border-radius: 100px; outline: none; cursor: pointer;
}
.control-slider::-webkit-slider-thumb {
-webkit-appearance: none; width: 24px; height: 24px;
border-radius: 50%; background: var(–neon);
box-shadow: 0 0 10px rgba(0,255,225,0.5); cursor: pointer;
}

/* Duration row */
.duration-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.dur-label { font-family: var(–font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(–muted); width: 100%; margin-bottom: 2px; }

/* Generate button */
.forge-btn {
width: 100%; padding: 18px;
border-radius: var(–radius); border: none;
background: var(–neon); color: #000;
font-family: var(–font-display); font-size: 24px;
letter-spacing: 4px; cursor: pointer;
box-shadow: 0 0 30px rgba(0,255,225,0.3);
transition: all 0.2s; position: relative; overflow: hidden;
-webkit-tap-highlight-color: transparent;
}
.forge-btn:active { transform: scale(0.97); box-shadow: 0 0 20px rgba(0,255,225,0.2); }
.forge-btn:disabled { background: var(–dim); color: var(–muted); cursor: not-allowed; box-shadow: none; }

/* Generation status */
.gen-status {
display: none; background: var(–surface);
border: 1px solid var(–border); border-radius: var(–radius);
padding: 20px; flex-direction: column; gap: 16px;
}
.gen-status.visible { display: flex; }
.status-anim { display: flex; align-items: center; gap: 3px; height: 36px; justify-content: center; }
.sw-bar { width: 3px; border-radius: 2px; background: var(–neon); animation: wave 0.8s ease-in-out infinite alternate; }
.sw-bar:nth-child(1){animation-delay:0s;height:16px}.sw-bar:nth-child(2){animation-delay:.1s;height:28px}.sw-bar:nth-child(3){animation-delay:.2s;height:22px}.sw-bar:nth-child(4){animation-delay:.3s;height:36px}.sw-bar:nth-child(5){animation-delay:.4s;height:18px}.sw-bar:nth-child(6){animation-delay:.5s;height:30px}.sw-bar:nth-child(7){animation-delay:.3s;height:14px}.sw-bar:nth-child(8){animation-delay:.1s;height:26px}
@keyframes wave { from{transform:scaleY(0.2);opacity:0.4} to{transform:scaleY(1);opacity:1} }
.status-label { font-size: 14px; font-weight: 600; text-align: center; }
.status-bar-bg { height: 5px; background: var(–dim); border-radius: 100px; overflow: hidden; }
.status-bar-fill {
height: 100%; background: linear-gradient(90deg, var(–neon), var(–neon3));
border-radius: 100px; width: 0%; transition: width 0.5s ease;
box-shadow: 0 0 10px var(–neon);
}
.status-steps { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
.status-step {
font-family: var(–font-mono); font-size: 10px; color: var(–dim);
display: flex; align-items: center; gap: 4px; transition: color 0.3s;
}
.status-step.active { color: var(–text); }
.status-step.done { color: var(–neon); }
.step-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
.cancel-btn {
background: none; border: 1px solid var(–border);
border-radius: 8px; padding: 12px;
color: var(–muted); width: 100%;
font-family: var(–font-body); font-size: 14px; cursor: pointer;
}
.cancel-btn:active { border-color: var(–neon2); color: var(–neon2); }

/* Result card */
.result-section { display: none; flex-direction: column; gap: 16px; }
.result-section.visible { display: flex; }
.result-card {
background: var(–surface); border: 1px solid var(–border);
border-radius: var(–radius); overflow: hidden;
}
.result-top {
padding: 18px;
background: linear-gradient(135deg, rgba(0,255,225,0.05), rgba(162,89,255,0.05));
border-bottom: 1px solid var(–border);
display: flex; gap: 14px; align-items: flex-start;
}
.result-art {
width: 64px; height: 64px; border-radius: 10px; flex-shrink: 0;
display: flex; align-items: center; justify-content: center;
font-size: 28px; position: relative;
}
.result-art::after {
content:’’; position:absolute; inset:-2px; border-radius:12px;
background: conic-gradient(var(–neon),var(–neon3),var(–neon2),var(–neon));
z-index:-1; animation:rotate 4s linear infinite; opacity:0.6;
}
@keyframes rotate{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.result-info { flex: 1; min-width: 0; }
.result-title { font-family: var(–font-display); font-size: 22px; letter-spacing: 2px; }
.result-tagline { font-size: 12px; color: var(–muted); margin-top: 3px; }
.result-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 8px; }
.result-tag {
font-family: var(–font-mono); font-size: 10px;
padding: 3px 7px; border-radius: 4px;
background: rgba(255,255,255,0.05); color: var(–muted);
}
.result-btns {
display: flex; gap: 10px; padding: 14px 18px;
border-bottom: 1px solid var(–border);
}
.rbtn {
flex: 1; padding: 12px 8px; border-radius: 10px;
border: 1px solid var(–border2); background: none;
color: var(–text); font-family: var(–font-body);
font-size: 13px; font-weight: 500; cursor: pointer;
display: flex; align-items: center; justify-content: center; gap: 6px;
transition: all 0.2s; text-decoration: none;
-webkit-tap-highlight-color: transparent;
}
.rbtn:active { background: var(–surface2); border-color: var(–neon); color: var(–neon); }
.rbtn.primary { background: var(–neon); color: #000; border-color: var(–neon); }
.rbtn.primary:active { background: #00e8cc; }

/* Waveform */
.waveform-section { padding: 16px 18px; }
.wave-display {
height: 60px; display: flex; align-items: center; gap: 1px;
cursor: pointer; margin-bottom: 12px;
}
.wave-bar { flex: 1; border-radius: 1px; background: var(–dim); transition: background 0.2s; }
.wave-bar.played { background: var(–neon); opacity: 0.9; }
.wave-bar.playing { background: var(–neon); box-shadow: 0 0 6px var(–neon); }
.wave-controls { display: flex; align-items: center; gap: 12px; }
.wave-play-btn {
width: 48px; height: 48px; border-radius: 50%;
background: var(–neon); color: #000; border: none;
display: flex; align-items: center; justify-content: center;
flex-shrink: 0; cursor: pointer;
box-shadow: 0 0 20px rgba(0,255,225,0.3);
-webkit-tap-highlight-color: transparent;
}
.wave-play-btn:active { transform: scale(0.93); }
.time-disp { font-family: var(–font-mono); font-size: 12px; color: var(–muted); white-space: nowrap; }
.vol-row { display: flex; align-items: center; gap: 8px; margin-left: auto; }
.vol-slider {
-webkit-appearance: none; width: 70px; height: 4px;
background: var(–dim); border-radius: 100px; outline: none; cursor: pointer;
}
.vol-slider::-webkit-slider-thumb {
-webkit-appearance: none; width: 16px; height: 16px;
border-radius: 50%; background: var(–muted); cursor: pointer;
}

/* Lyrics display */
.lyrics-display { padding: 0 18px 18px; border-top: 1px solid var(–border); padding-top: 16px; }
.lyrics-hdr { font-family: var(–font-mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(–muted); margin-bottom: 10px; }
.lyrics-body { font-size: 14px; line-height: 2; color: rgba(238,238,248,0.7); white-space: pre-line; font-style: italic; font-weight: 300; }

/* Variations */
.vars-section { display: flex; flex-direction: column; gap: 10px; }
.vars-label { font-family: var(–font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(–muted); }
.vars-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.var-card {
background: var(–surface); border: 1px solid var(–border);
border-radius: 10px; padding: 14px;
display: flex; gap: 10px; align-items: center;
cursor: pointer; -webkit-tap-highlight-color: transparent;
transition: border-color 0.2s;
}
.var-card:active { border-color: var(–neon3); }
.var-art { width: 38px; height: 38px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
.var-lbl { font-family: var(–font-mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(–muted); margin-bottom: 2px; }
.var-name { font-size: 12px; font-weight: 600; }

/* ── SONGS PANEL ── */
.songs-empty { text-align: center; padding: 60px 20px; color: var(–muted); font-size: 14px; }
.songs-empty .empty-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.4; }
.songs-grid { display: flex; flex-direction: column; gap: 2px; }
.song-row {
display: flex; gap: 12px; align-items: center;
padding: 14px 4px; border-radius: 10px;
cursor: pointer; -webkit-tap-highlight-color: transparent;
transition: background 0.15s; position: relative;
}
.song-row:active { background: var(–surface2); }
.song-row.active { background: rgba(0,255,225,0.05); }
.song-row.active::before { content:’’; position:absolute; left:0; top:20%; bottom:20%; width:2px; background:var(–neon); border-radius:2px; box-shadow:0 0 8px var(–neon); }
.song-art { width: 50px; height: 50px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
.song-info { flex: 1; min-width: 0; }
.song-name { font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.song-row.active .song-name { color: var(–neon); }
.song-meta { font-size: 11px; color: var(–muted); font-family: var(–font-mono); margin-top: 3px; }
.song-dur { font-family: var(–font-mono); font-size: 12px; color: var(–muted); flex-shrink: 0; }

/* ── MINI PLAYER (bottom) ── */
.mini-player {
position: fixed; bottom: 0; left: 0; right: 0;
background: rgba(10,10,22,0.97);
backdrop-filter: blur(20px);
border-top: 1px solid var(–border2);
z-index: 80; padding: 10px 16px 12px;
}
.mini-player-inner {
display: flex; gap: 12px; align-items: center;
}
.mini-art {
width: 44px; height: 44px; border-radius: 8px;
display: flex; align-items: center; justify-content: center;
font-size: 20px; flex-shrink: 0;
background: var(–surface2);
}
.mini-info { flex: 1; min-width: 0; }
.mini-title { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.mini-sub { font-size: 11px; color: var(–muted); font-family: var(–font-mono); margin-top: 2px; }
.mini-play {
width: 42px; height: 42px; border-radius: 50%;
background: var(–neon); color: #000; border: none;
display: flex; align-items: center; justify-content: center;
flex-shrink: 0; cursor: pointer;
box-shadow: 0 0 16px rgba(0,255,225,0.35);
-webkit-tap-highlight-color: transparent;
}
.mini-play:active { transform: scale(0.92); }

/* ── TOAST ── */
.toast {
position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%) translateY(10px);
background: var(–surface); border: 1px solid var(–border2);
border-radius: 100px; padding: 10px 20px;
font-size: 13px; color: var(–text);
box-shadow: 0 8px 32px rgba(0,0,0,0.4);
opacity: 0; transition: all 0.3s; pointer-events: none;
white-space: nowrap; z-index: 9998;
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* ── DOT LOADER ── */
.dot-loader { display: inline-flex; gap: 3px; align-items: center; vertical-align: middle; margin-left: 4px; }
.dot-loader span {
width: 4px; height: 4px; border-radius: 50%;
background: var(–neon); animation: dotpulse 1.2s ease-in-out infinite;
}
.dot-loader span:nth-child(2){animation-delay:.2s}
.dot-loader span:nth-child(3){animation-delay:.4s}
@keyframes dotpulse{0%,100%{opacity:0.2;transform:scale(0.8)}50%{opacity:1;transform:scale(1)}}

/* ── MODAL ── */
.modal-overlay {
position: fixed; inset: 0;
background: rgba(0,0,0,0.88); backdrop-filter: blur(8px);
z-index: 10000; display: flex; align-items: flex-end;
padding: 0;
}
@media (min-width: 500px) {
.modal-overlay { align-items: center; padding: 20px; }
}
.modal-box {
background: var(–surface); border: 1px solid var(–border2);
border-radius: 20px 20px 0 0; padding: 28px 24px 40px;
width: 100%; max-width: 480px;
box-shadow: 0 -20px 60px rgba(0,0,0,0.5);
}
@media (min-width: 500px) {
.modal-box { border-radius: 20px; padding: 36px; }
}
.modal-handle {
width: 40px; height: 4px; background: var(–dim);
border-radius: 2px; margin: 0 auto 24px;
}
@media (min-width: 500px) { .modal-handle { display: none; } }
.modal-title { font-family: var(–font-display); font-size: 26px; letter-spacing: 3px; margin-bottom: 6px; }
.modal-sub { font-size: 13px; color: var(–muted); line-height: 1.7; margin-bottom: 22px; }
.steps-box {
background: var(–surface2); border-radius: 12px;
padding: 18px; margin-bottom: 20px; border: 1px solid var(–border);
}
.steps-box-title { font-family: var(–font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(–muted); margin-bottom: 14px; }
.step-item { display: flex; gap: 12px; align-items: flex-start; font-size: 13px; margin-bottom: 12px; }
.step-item:last-child { margin-bottom: 0; }
.step-num {
width: 22px; height: 22px; border-radius: 50%;
background: rgba(0,255,225,0.15); color: var(–neon);
display: flex; align-items: center; justify-content: center;
font-family: var(–font-mono); font-size: 11px; flex-shrink: 0; margin-top: 1px;
}
.token-input-wrap { margin-bottom: 20px; }
