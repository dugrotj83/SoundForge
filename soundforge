  if (el) el.textContent = v + '/500';
}
function updateCharCountD() {
  const v = document.getElementById('dPromptInput') ? document.getElementById('dPromptInput').value.length : 0;
  const el = document.getElementById('dCharCount');
  if (el) el.textContent = v + '/500';
}

function addTag(btn, tag) {
  btn.classList.toggle('selected');
  const input = document.getElementById('promptInput');
  if (!input) return;
  input.value = btn.classList.contains('selected')
    ? (input.value + ' ' + tag).trim()
    : input.value.replace(new RegExp('\\b' + tag + '\\b', 'g'), '').replace(/\s+/g,' ').trim();
  updateCharCount();
}
function addTagD(btn, tag) {
  btn.classList.toggle('selected');
  const input = document.getElementById('dPromptInput');
  if (!input) return;
  input.value = btn.classList.contains('selected')
    ? (input.value + ' ' + tag).trim()
    : input.value.replace(new RegExp('\\b' + tag + '\\b', 'g'), '').replace(/\s+/g,' ').trim();
  updateCharCountD();
}

// Lyrics generation for both layouts
function generateLyrics() {
  const genre = document.getElementById('genreSelect').value;
  const mood = document.getElementById('moodSelect').value;
  const bpm = document.getElementById('bpmVal').textContent;
  const meta = generateMetadata('', genre, mood, bpm);
  const el = document.getElementById('lyricsInput');
  if (el) el.value = meta.lyrics;
  showToast('Lyrics generated!', '✍️');
}
function generateLyricsD() {
  const genre = document.getElementById('dGenreSelect').value;
  const mood = document.getElementById('dMoodSelect').value;
  const bpm = document.getElementById('dBpmVal').textContent;
  const meta = generateMetadata('', genre, mood, bpm);
  const el = document.getElementById('dLyricsInput');
  if (el) el.value = meta.lyrics;
  showToast('Lyrics generated!', '✍️');
}

// ── STATUS helpers (shared by mobile + desktop) ──
function setStatus(label, progress) {
  ['statusTitle','dStatusTitle'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = label + ' <div class="dot-loader" style="display:inline-flex"><span></span><span></span><span></span></div>';
  });
  ['statusBar','dStatusBar'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.style.width = progress + '%';
  });
}
function markStep(id, state) {
  // mobile: step1-4, desktop: dStep1-4
  [id, 'd' + id.charAt(0).toUpperCase() + id.slice(1)].forEach(sid => {
    const el = document.getElementById(sid);
    if (el) { el.classList.remove('done','active'); if (state) el.classList.add(state); }
  });
}

// ── GENERATION STARTERS ──
function getActiveInputs() {
  if (isMobile()) {
    return {
      prompt: (document.getElementById('promptInput')||{value:''}).value.trim(),
      genre: (document.getElementById('genreSelect')||{value:'Electronic'}).value,
      mood: (document.getElementById('moodSelect')||{value:'Melancholic'}).value,
      bpm: (document.getElementById('bpmVal')||{textContent:'88'}).textContent,
      lyrics: (document.getElementById('lyricsInput')||{value:''}).value.trim(),
    };
  } else {
    return {
      prompt: (document.getElementById('dPromptInput')||{value:''}).value.trim(),
      genre: (document.getElementById('dGenreSelect')||{value:'Electronic'}).value,
      mood: (document.getElementById('dMoodSelect')||{value:'Melancholic'}).value,
      bpm: (document.getElementById('dBpmVal')||{textContent:'88'}).textContent,
      lyrics: (document.getElementById('dLyricsInput')||{value:''}).value.trim(),
    };
  }
}
function getGenBtn() { return isMobile() ? document.getElementById('generateBtn') : document.getElementById('dGenerateBtn'); }
function getStatusEl() { return isMobile() ? document.getElementById('genStatus') : document.getElementById('dGenStatus'); }
function getResultSection() { return isMobile() ? document.getElementById('resultSection') : document.getElementById('dResultSection'); }
function getResultCard() { return isMobile() ? document.getElementById('resultCard') : document.getElementById('dResultCard'); }
function getVarsRow() { return isMobile() ? document.getElementById('variationsRow') : document.getElementById('dVariationsRow'); }

// Override startGeneration to use active inputs
async function startGeneration() { await _startGen(); }
async function startGenerationD() { await _startGen(); }

async function _startGen() {
  const inputs = getActiveInputs();
  if (!inputs.prompt) { showToast('Add a description first', '⚠️'); return; }

  cancelRequested = false;
  const genBtn = getGenBtn();
  const statusEl = getStatusEl();
  const resultEl = getResultSection();
  if (genBtn) genBtn.disabled = true;
  if (statusEl) statusEl.classList.add('visible');
  if (resultEl) resultEl.classList.remove('visible');

  const { prompt, genre, mood, bpm, lyrics: customLyrics } = inputs;
  const durationSecs = DURATION_MAP[selectedDuration] || 8;
  const isInstrumental = currentMode === 'instrumental';
  const meta = generateMetadata(prompt, genre, mood, bpm);
  const songLyrics = customLyrics || meta.lyrics;
  let audioUrl = null;

  try {
    markStep('step1', 'active');
    setStatus('Crafting your prompt…', 15);
    await new Promise(r => setTimeout(r, 500));
    if (cancelRequested) throw new Error('cancelled');

    markStep('step1', 'done'); markStep('step2', 'active');
    setStatus('Composing structure…', 35);
    await new Promise(r => setTimeout(r, 600));
    if (cancelRequested) throw new Error('cancelled');

    markStep('step2', 'done'); markStep('step3', 'active');
    setStatus('Generating audio with MusicGen…', 55);

    const musicPrompt = `${genre}, ${mood}, ${bpm} BPM. ${prompt}${isInstrumental?', no vocals, instrumental':''}`;

    if (!demoMode && HF_KEY) {
      audioUrl = await generateMusicHF(musicPrompt, durationSecs);
    } else {
      for (let p = 55; p <= 88; p += 5) {
        if (cancelRequested) throw new Error('cancelled');
        await new Promise(r => setTimeout(r, 500));
        setStatus('Generating audio with MusicGen…', p);
      }
    }

    if (cancelRequested) throw new Error('cancelled');
    markStep('step3', 'done'); markStep('step4', 'active');
    setStatus('Mastering…', 95);
    await new Promise(r => setTimeout(r, 500));
    markStep('step4', 'done');
    setStatus('Done!', 100);
    await new Promise(r => setTimeout(r, 300));

  } catch (err) {
    if (statusEl) statusEl.classList.remove('visible');
    if (genBtn) genBtn.disabled = false;
    ['step1','step2','step3','step4'].forEach(id => markStep(id, null));
    setStatus('', 0);
    if (err.message !== 'cancelled') showToast('Error: ' + err.message, '❌');
    return;
  }

  if (statusEl) statusEl.classList.remove('visible');
  if (genBtn) genBtn.disabled = false;
  ['step1','step2','step3','step4'].forEach(id => markStep(id, null));
  setStatus('', 0);

  const emoji = EMOJIS[Math.floor(Math.random()*EMOJIS.length)];
  const gradient = GRADIENTS[Math.floor(Math.random()*GRADIENTS.length)];
  const song = { title: meta.title, tagline: meta.tagline, tags: meta.tags, emoji, gradient, duration: selectedDuration, genre, mood, bpm, lyrics: songLyrics, prompt, audioUrl, isDemo: !audioUrl };

  songs.unshift(song);
  currentSongIdx = 0;
  renderResult(song);
  renderSongsList();
  updateNowPlayingAll(song);
  showToast(`"${meta.title}" created!`, '🎵');
}

function cancelGeneration() { _cancelGen(); }
function cancelGenerationD() { _cancelGen(); }
function _cancelGen() {
  cancelRequested = true;
  const statusEl = getStatusEl();
  const genBtn = getGenBtn();
  if (statusEl) statusEl.classList.remove('visible');
  if (genBtn) genBtn.disabled = false;
  ['step1','step2','step3','step4'].forEach(id => markStep(id, null));
  setStatus('', 0);
  showToast('Cancelled', '✕');
}

// ── RENDER RESULT (works for both layouts) ──
function renderResult(song) {
  const resultEl = getResultSection();
  const cardEl = getResultCard();
  const varsEl = getVarsRow();
  if (!resultEl || !cardEl) return;
  resultEl.classList.add('visible');

  const bars = Array.from({length:80}, () => Math.random()*0.7+0.3);
  const waveHtml = bars.map(h => `<div class="wave-bar" style="height:${h*100}%"></div>`).join('');
  const audioId = isMobile() ? 'resultAudio' : 'dResultAudio';
  const wavePlayId = isMobile() ? 'wavePlayBtn' : 'dWavePlayBtn';
  const playResultId = isMobile() ? 'playResultBtn' : 'dPlayResultBtn';
  const timeId = isMobile() ? 'audioTimeDisplay' : 'dAudioTimeDisplay';
  const waveId = isMobile() ? 'waveDisplay' : 'dWaveDisplay';

  cardEl.innerHTML = `
    <div class="result-top">
      <div class="result-art" style="background:${song.gradient}">${song.emoji}</div>
      <div class="result-info">
        <div class="result-title">${song.title}</div>
        <div class="result-tagline">${song.tagline}</div>
        <div class="result-tags">
          ${song.tags.map(t=>`<div class="result-tag">${t}</div>`).join('')}
          ${song.audioUrl ? '<div class="result-tag" style="color:var(--neon);border-color:rgba(0,255,225,0.3)">🎵 REAL AUDIO</div>' : '<div class="result-tag" style="color:var(--gold)">🎭 DEMO</div>'}
        </div>
      </div>
    </div>
    <div class="result-btns">
      ${song.audioUrl
        ? `<a class="rbtn" href="${song.audioUrl}" download="${song.title}.wav">
             <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
             Download
           </a>`
        : `<button class="rbtn" onclick="openApiModal()">
             <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
             Get Audio
           </button>`}
      <button class="rbtn primary" id="${playResultId}" onclick="playResultAudio('${song.audioUrl||''}')">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        ${song.audioUrl ? 'Play' : 'Preview'}
      </button>
    </div>
    <div class="waveform-section">
      <audio id="${audioId}" ${song.audioUrl?`src="${song.audioUrl}"`:''}  style="display:none"
        onended="onAudioEnded()" ontimeupdate="syncWaveform()" onloadedmetadata="onAudioLoaded()"></audio>
      <div class="wave-display" id="${waveId}" onclick="seekWaveAudio(event)">${waveHtml}</div>
      <div class="wave-controls">
        <button class="wave-play-btn" id="${wavePlayId}" onclick="playResultAudio('${song.audioUrl||''}')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </button>
        <span class="time-disp" id="${timeId}">0:00 / ${song.duration}</span>
        <div class="vol-row">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/></svg>
          <input type="range" class="vol-slider" min="0" max="100" value="80" oninput="setAudioVolume(this.value)">
        </div>
      </div>
    </div>
    ${song.lyrics ? `<div class="lyrics-display"><div class="lyrics-hdr">Lyrics</div><div class="lyrics-body">${song.lyrics}</div></div>` : ''}
  `;

  if (varsEl) {
    const ve = ['🌊','🔥','❄️','💫'];
    const vl = ['Acoustic','Remix','Ambient','Bass Boost'];
    varsEl.innerHTML = ve.map((e,i) => `
      <div class="var-card" onclick="showToast('Tweak your prompt to create a variation!','💡')">
        <div class="var-art" style="background:${GRADIENTS[(i+2)%GRADIENTS.length]}">${e}</div>
        <div><div class="var-lbl">Variation ${i+1}</div><div class="var-name">${song.title} — ${vl[i]}</div></div>
      </div>
    `).join('');
  }

  setTimeout(() => document.querySelectorAll('.wave-bar').forEach((b,i) =>
    setTimeout(() => { b.style.background='var(--dim)'; b.style.opacity='0.6'; }, i*6)), 100);
}

// ── AUDIO PLAYER ──
function getAudioEl() {
  return document.getElementById('resultAudio') || document.getElementById('dResultAudio');
}
function playResultAudio(url) {
  const audio = getAudioEl();
  if (!audio) return;
  if (!url) { showToast('Add your free HF token to generate real audio', '⚠️'); return; }
  if (audio.paused) {
    audio.play().then(() => { updatePlayBtns(true); if(songs[currentSongIdx]) updateNowPlayingAll(songs[currentSongIdx]); })
      .catch(e => showToast('Playback error: ' + e.message, '❌'));
  } else {
    audio.pause(); updatePlayBtns(false);
  }
}
function toggleGlobalPlay() {
  const audio = getAudioEl();
  if (audio && audio.src && !audio.src.endsWith(window.location.href)) {
    audio.paused ? audio.play().then(()=>updatePlayBtns(true)) : (audio.pause(), updatePlayBtns(false));
  } else {
    showToast(songs.length ? 'Generate a track first' : 'Generate a track first', '⚠️');
  }
}
function onAudioEnded() { updatePlayBtns(false); }
function onAudioLoaded() {
  const audio = getAudioEl();
  if (!audio) return;
  const m=Math.floor(audio.duration/60), s=Math.floor(audio.duration%60);
  ['audioTimeDisplay','dAudioTimeDisplay'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = `0:00 / ${m}:${s.toString().padStart(2,'0')}`;
  });
}
function syncWaveform() {
  const audio = getAudioEl();
  if (!audio||!audio.duration) return;
  const ratio = audio.currentTime/audio.duration;
  const bars = document.querySelectorAll('.wave-bar');
  const split = Math.floor(ratio*bars.length);
  bars.forEach((b,i) => { b.classList.toggle('played',i<split); b.classList.toggle('playing',i===split); });
  const fmt = t => `${Math.floor(t/60)}:${Math.floor(t%60).toString().padStart(2,'0')}`;
  ['audioTimeDisplay','dAudioTimeDisplay'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = `${fmt(audio.currentTime)} / ${fmt(audio.duration)}`;
  });
}
function seekWaveAudio(e) {
  const audio = getAudioEl();
  if (!audio||!audio.duration) return;
  audio.currentTime = (e.offsetX/e.currentTarget.clientWidth)*audio.duration;
  syncWaveform();
}
function setAudioVolume(val) {
  const audio = getAudioEl();
  if (audio) audio.volume = val/100;
}

// Show modal on load
window.addEventListener('load', () => {
  document.getElementById('apiModal').style.display = 'flex';
});
</script>

